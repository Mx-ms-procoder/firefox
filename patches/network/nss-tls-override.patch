  * License, v. 2.0. */
+#include "CamouTLSOverride.hpp"
+
 #include "nsNSSComponent.h"

 #include "CryptoTask.h"
@@ -1200,6 +1202,14 @@ nsresult nsNSSComponent::InitializeNSS() {
   SSL_OptionSetDefault(SSL_ENABLE_0RTT_DATA, true);
   SSL_OptionSetDefault(SSL_ENABLE_POST_HANDSHAKE_AUTH, true);

+  // ── Camoufox TLS Override ────────────────────────────────────────
+  // Apply CAMOU_TLS_* environment variable overrides AFTER NSS is fully
+  // initialized but BEFORE any connections are attempted. This ensures
+  // the TLS Client Hello matches the identity selected by the
+  // IdentityCoherenceEngine.
+  CamouTLSOverride::ApplyAll();
+  // ────────────────────────────────────────────────────────────────
+
   rv = CommonInit();

   MOZ_LOG(gPIPNSSLog, LogLevel::Debug, ("NSS Initialization done\n"));
